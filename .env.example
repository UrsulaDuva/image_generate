# =====================================================================
# AI 图像工坊 - 环境变量示例
# 复制为 .env 后按需填入真实值；切勿将带密钥的 .env 提交到仓库
# =====================================================================

# ---------------------------------------------------------------------
# 图片生成 API（OpenAI 兼容 /images/generations 接口）
# ---------------------------------------------------------------------
API_URL=https://your-image-endpoint.example.com/v1/images/generations
API_KEY=
MODEL=your-image-model-id
SIZE=1024x1024
OUTPUT_DIR=./history/outputs

# 默认提示词（命令行不传时使用）
PROMPT=a serene landscape, soft light, cinematic composition

# ---------------------------------------------------------------------
# 多模态理解 API（图片反推 / 视觉分析，OpenAI 兼容 /chat/completions）
# ---------------------------------------------------------------------
VISION_API_URL=https://your-vision-endpoint.example.com/v1/chat/completions
VISION_API_KEY=
VISION_MODEL=your-vision-model-id

# ---------------------------------------------------------------------
# 文案生成 API（Chat，OpenAI 兼容 /chat/completions）
# ---------------------------------------------------------------------
CHAT_API_URL=https://your-chat-endpoint.example.com/v1/chat/completions
CHAT_API_KEY=
CHAT_MODEL=your-chat-model-id

# 可选：Agent 专用模型（不配置则回退到 CHAT_MODEL）
# AGENT_MODEL=your-agent-model-id

# ---------------------------------------------------------------------
# 视频生成（可选，bytedance/doubao-seedance 系列等）
# ---------------------------------------------------------------------
# VIDEO_API_KEY=
# VIDEO_MODEL=

# ---------------------------------------------------------------------
# 初始管理员密码（首次启动时若 data/user_passwords.json 无 admin 则使用）
# ---------------------------------------------------------------------
INITIAL_ADMIN_PASSWORD=change-me-please
