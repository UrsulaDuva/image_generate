# API配置
API_URL=https://your-api-url/images/generations
API_KEY=your-api-key-here
MODEL=gemini-3.1-flash-image-preview-2k

# 首次启动账号初始化
# 首次创建 data/user_passwords.json 时会读取这些值；不会再使用代码里的固定默认密码。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-admin-password
# 可选：同时初始化一个普通用户；也可以启动后在管理员后台新增。
INITIAL_USER_USERNAME=your-user-account
INITIAL_USER_PASSWORD=change-this-user-password
INITIAL_USER_CREDITS=50
INITIAL_ADMIN_CREDITS=1000

# 可选配置
# SIZE=1024x1024
# OUTPUT_DIR=./history/outputs
# SESSION_MAX_AGE_SECONDS=604800

# 图片生成网页端请求优化
# 失败重试次数越少，接口异常时返回越快；正常成功速度主要取决于上游模型。
# IMAGE_API_MAX_ATTEMPTS=2
# IMAGE_API_TIMEOUT_SECONDS=120

# 图片反推 / 多模态理解 API 配置（OpenAI 兼容）
VISION_API_URL=https://coding.dashscope.aliyuncs.com/v1/chat/completions
VISION_API_KEY=your-vision-api-key-here
VISION_MODEL=qwen3.6-plus

# 文案生成 / 智能助手 API 配置（OpenAI 兼容）
CHAT_API_URL=https://your-chat-api-url/chat/completions
CHAT_API_KEY=your-chat-api-key-here
CHAT_MODEL=deepseek/deepseek-v4-flash-free

# 视频生成 API 配置
# 默认复用 CHAT_API_KEY；如需单独配置视频 Key，取消下一行注释。
# VIDEO_API_KEY=your-video-api-key-here
